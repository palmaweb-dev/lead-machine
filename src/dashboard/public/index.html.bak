<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Lead Machine — Painel</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: -apple-system, sans-serif; background: #0f172a; color: #e2e8f0; }
    .header { background: #1e293b; padding: 20px 30px; border-bottom: 1px solid #334155; }
    .header h1 { font-size: 22px; color: #38bdf8; }
    .container { max-width: 1200px; margin: 0 auto; padding: 30px; }
    .cards { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-bottom: 30px; }
    .card { background: #1e293b; padding: 20px; border-radius: 12px; text-align: center; }
    .card .valor { font-size: 36px; font-weight: bold; color: #38bdf8; }
    .card .label { font-size: 13px; color: #94a3b8; margin-top: 6px; }
    .panel { background: #1e293b; padding: 24px; border-radius: 12px; margin-bottom: 20px; }
    .panel h2 { font-size: 16px; margin-bottom: 16px; color: #cbd5e1; }
    input, select { background: #0f172a; border: 1px solid #334155; color: #e2e8f0;
                    padding: 10px 14px; border-radius: 8px; width: 100%; margin-bottom: 12px; }
    button { background: #0ea5e9; color: white; border: none; padding: 12px 24px;
             border-radius: 8px; cursor: pointer; font-size: 14px; }
    button:hover { background: #0284c7; }
    .btn-danger { background: #ef4444; }
    table { width: 100%; border-collapse: collapse; font-size: 13px; }
    th { background: #0f172a; padding: 10px; text-align: left; color: #94a3b8; }
    td { padding: 10px; border-bottom: 1px solid #1e293b; }
    .badge { padding: 3px 8px; border-radius: 20px; font-size: 11px; }
    .quente { background: #dc2626; } .morno { background: #d97706; } .frio { background: #3b82f6; }
    .contatado { background: #8b5cf6; } .respondeu { background: #10b981; }
  </style>
</head>
<body>
  <div class="header">
    <h1>🤖 Lead Machine — Painel de Controle</h1>
  </div>
  <div class="container">

    <!-- Métricas -->
    <div class="cards">
      <div class="card"><div class="valor" id="m-total">—</div><div class="label">Total Leads</div></div>
      <div class="card"><div class="valor" id="m-enviados">—</div><div class="label">Enviados Hoje</div></div>
      <div class="card"><div class="valor" id="m-respostas">—</div><div class="label">Respostas Hoje</div></div>
      <div class="card"><div class="valor" id="m-reunioes">—</div><div class="label">Reuniões Hoje</div></div>
    </div>

    <!-- Controle -->
    <div class="panel">
      <h2>🚀 Iniciar Prospecção</h2>
      <input id="segmento" placeholder="Segmento (ex: clínica, advogado, dentista)">
      <input id="cidade" placeholder="Cidade (ex: São Paulo, Campinas)">
      <input id="limite" type="number" placeholder="Limite de empresas (padrão: 20)" value="20">
      <div style="display:flex;gap:12px">
        <button onclick="iniciarProspeccao()">▶️ Iniciar</button>
        <button class="btn-danger" onclick="pausar()">⏸️ Pausar</button>
      </div>
      <p id="status-msg" style="margin-top:12px;color:#94a3b8;font-size:13px"></p>
    </div>

    <!-- Leads -->
    <div class="panel">
      <h2>📋 Leads Recentes</h2>
      <table>
        <thead>
          <tr><th>Empresa</th><th>WhatsApp</th><th>Site</th><th>Score</th><th>Status</th><th>Interesse</th></tr>
        </thead>
        <tbody id="tabela-leads"></tbody>
      </table>
    </div>
  </div>

  <script>
    const API_KEY = prompt('Senha do painel:') || '';
    const h = { 'Content-Type': 'application/json', 'x-api-key': API_KEY };

    async function carregarMetricas() {
      const r = await fetch('/api/metricas', { headers: h });
      const m = await r.json();
      document.getElementById('m-total').textContent = m.total_leads || 0;
      document.getElementById('m-enviados').textContent = m.enviados_hoje || 0;
      document.getElementById('m-respostas').textContent = m.responderam_hoje || 0;
      document.getElementById('m-reunioes').textContent = m.reunioes_hoje || 0;
    }

    async function carregarLeads() {
      const r = await fetch('/api/leads', { headers: h });
      const leads = await r.json();
      const tbody = document.getElementById('tabela-leads');
      tbody.innerHTML = leads.map(l => `
        <tr>
          <td>${l.nome_empresa}</td>
          <td>${l.whatsapp || '—'}</td>
          <td>${l.site ? `<a href="${l.site}" target="_blank" style="color:#38bdf8">🔗</a>` : '—'}</td>
          <td>${l.score || '—'}</td>
          <td><span class="badge ${l.status}">${l.status}</span></td>
          <td><span class="badge ${l.interesse || ''}">${l.interesse || '—'}</span></td>
        </tr>`).join('');
    }

    async function iniciarProspeccao() {
      const body = {
        segmento: document.getElementById('segmento').value,
        cidade: document.getElementById('cidade').value,
        limite: parseInt(document.getElementById('limite').value) || 20
      };
      const r = await fetch('/api/prospeccao/iniciar', { method: 'POST', headers: h, body: JSON.stringify(body) });
      const d = await r.json();
      document.getElementById('status-msg').textContent = '✅ ' + d.mensagem;
    }

    async function pausar() {
      await fetch('/api/prospeccao/pausar', { method: 'POST', headers: h });
      document.getElementById('status-msg').textContent = '⏸️ Automação pausada';
    }

    // Atualizar a cada 15s
    carregarMetricas(); carregarLeads();
    setInterval(() => { carregarMetricas(); carregarLeads(); }, 15000);
  </script>
</body>
</html>
